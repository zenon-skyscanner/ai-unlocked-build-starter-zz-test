---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import HotelsSearch from '../components/HotelsSearch';
---

<Layout>
	<Navigation currentPath="/hotels" />

	<main class="container mx-auto px-4 py-12">
		<section class="text-center mb-16">
			<h1 class="text-5xl font-bold text-blue-600 mb-4">Hotel Search</h1>
			<p class="text-xl text-gray-600">Search live hotel prices</p>
		</section>
		<section class="max-w-3xl mx-auto">
			<HotelsSearch client:load />
		</section>
	</main>
</Layout>
