---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import { db, RailTrip, eq, and, gte } from 'astro:db';

// Get search params from URL
const url = new URL(Astro.request.url);
const origin = url.searchParams.get('origin') || '';
const destination = url.searchParams.get('destination') || '';
const departureDate = url.searchParams.get('departureDate') || '';

// Query rail trips based on search criteria
let trips = [];
if (origin || destination || departureDate) {
  // Build filter conditions
  let allTrips = await db.select().from(RailTrip).all();

  trips = allTrips.filter(trip => {
    let matches = true;

    if (origin && trip.origin !== origin) {
      matches = false;
    }

    if (destination && trip.destination !== destination) {
      matches = false;
    }

    if (departureDate) {
      const searchDate = new Date(departureDate);
      const tripDate = new Date(trip.departureDateTime);
      // Compare only the date part (ignore time)
      searchDate.setHours(0, 0, 0, 0);
      tripDate.setHours(0, 0, 0, 0);

      if (tripDate < searchDate) {
        matches = false;
      }
    }

    return matches;
  });
}

// Helper function to format duration
function formatDuration(minutes: number): string {
  const hours = Math.floor(minutes / 60);
  const mins = minutes % 60;
  if (hours === 0) return `${mins}m`;
  if (mins === 0) return `${hours}h`;
  return `${hours}h ${mins}m`;
}

// Helper function to format date/time
function formatDateTime(dateTime: Date): string {
  const date = new Date(dateTime);
  return date.toLocaleTimeString('en-US', {
    hour: '2-digit',
    minute: '2-digit',
    hour12: false
  });
}

// Get unique cities for datalist suggestions
const allTrips = await db.select().from(RailTrip).all();
const cities = [...new Set([
  ...allTrips.map(t => t.origin),
  ...allTrips.map(t => t.destination)
])].sort();
---

<Layout>
	<Navigation currentPath="/rail-search" />

	<main class="relative pb-20">
		<!-- Hero Section -->
		<section class="relative overflow-hidden py-16 mb-12">
			<div class="absolute inset-0 bg-gradient-to-br from-indigo-50 via-purple-50 to-pink-50"></div>
			<div class="absolute inset-0 dots-pattern opacity-20"></div>

			<div class="container mx-auto px-4 relative z-10">
				<div class="text-center max-w-3xl mx-auto">
					<div class="inline-block mb-4 px-4 py-2 rounded-full bg-white shadow-md">
						<span class="text-sm font-semibold text-purple-600">🚄 Real-time Search</span>
					</div>
					<h1 class="text-7xl font-black heading-gradient mb-6">
						Rail Search
					</h1>
					<p class="text-2xl text-gray-600 font-light">Find your perfect train journey across <span class="font-semibold text-orange-500">Italy</span></p>
				</div>
			</div>
		</section>

		<!-- Search Form -->
		<section class="max-w-5xl mx-auto mb-16 px-4">
			<form method="GET" action="/rail-search" class="glass rounded-3xl shadow-2xl p-8 md:p-12 border-2 border-white/50">
				<div class="grid md:grid-cols-3 gap-6 mb-8">
					<div class="group">
						<label for="origin" class="flex items-center gap-2 text-sm font-bold text-gray-700 mb-3">
							<span class="text-xl">📍</span>
							<span>From</span>
						</label>
						<input
							type="text"
							id="origin"
							name="origin"
							value={origin}
							list="cities"
							placeholder="e.g., Rome"
							class="w-full px-5 py-4 bg-white border-2 border-gray-200 rounded-2xl text-lg font-medium focus:ring-0 focus:border-purple-400 transition-all hover:border-purple-300"
						/>
					</div>

					<div class="group">
						<label for="destination" class="flex items-center gap-2 text-sm font-bold text-gray-700 mb-3">
							<span class="text-xl">🎯</span>
							<span>To</span>
						</label>
						<input
							type="text"
							id="destination"
							name="destination"
							value={destination}
							list="cities"
							placeholder="e.g., Milan"
							class="w-full px-5 py-4 bg-white border-2 border-gray-200 rounded-2xl text-lg font-medium focus:ring-0 focus:border-purple-400 transition-all hover:border-purple-300"
						/>
					</div>

					<div class="group">
						<label for="departureDate" class="flex items-center gap-2 text-sm font-bold text-gray-700 mb-3">
							<span class="text-xl">📅</span>
							<span>Departure</span>
						</label>
						<input
							type="date"
							id="departureDate"
							name="departureDate"
							value={departureDate}
							class="w-full px-5 py-4 bg-white border-2 border-gray-200 rounded-2xl text-lg font-medium focus:ring-0 focus:border-purple-400 transition-all hover:border-purple-300"
						/>
					</div>
				</div>

				<div class="text-center">
					<button
						type="submit"
						class="btn-primary cursor-pointer text-xl group"
					>
						🔍 Search Trains
						<svg class="inline-block w-6 h-6 ml-2 transform group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
						</svg>
					</button>
				</div>
			</form>

			<!-- Datalist for city suggestions -->
			<datalist id="cities">
				{cities.map(city => <option value={city} />)}
			</datalist>
		</section>

		<!-- Search Results -->
		{(origin || destination || departureDate) && (
			<section class="max-w-6xl mx-auto px-4">
				{trips.length > 0 ? (
					<>
						<div class="flex items-center justify-between mb-8">
							<h2 class="text-3xl font-black heading-gradient">
								Found {trips.length} {trips.length === 1 ? 'trip' : 'trips'} ✨
							</h2>
							<div class="px-4 py-2 rounded-full bg-gradient-to-r from-green-100 to-emerald-100 border-2 border-green-200">
								<span class="text-green-700 font-bold text-sm">🎉 Available Now</span>
							</div>
						</div>
						<div class="space-y-6">
							{trips.map((trip, index) => (
								<div class="card group cursor-pointer" style={`animation-delay: ${index * 0.05}s`}>
									<div class="p-6 md:p-8">
										<div class="grid md:grid-cols-12 gap-6 items-center">
											<!-- Origin Station -->
											<div class="md:col-span-3 text-center md:text-left">
												<div class="inline-block mb-2 px-3 py-1 rounded-full bg-gradient-to-r from-indigo-100 to-purple-100 text-purple-700 text-xs font-bold">
													DEPARTURE
												</div>
												<div class="text-4xl font-black text-gray-800">{formatDateTime(trip.departureDateTime)}</div>
												<div class="text-xl font-bold text-purple-600 mt-2 flex items-center justify-center md:justify-start gap-2">
													<span>📍</span>
													<span>{trip.origin}</span>
												</div>
											</div>

											<!-- Journey Visualization -->
											<div class="md:col-span-3 flex flex-col items-center justify-center">
												<div class="relative w-full">
													<div class="h-1 bg-gradient-to-r from-purple-400 via-pink-400 to-orange-400 rounded-full"></div>
													<div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2">
														<div class="bg-white rounded-full p-3 shadow-lg border-2 border-orange-400">
															<span class="text-2xl">🚄</span>
														</div>
													</div>
												</div>
												<div class="mt-4 px-4 py-2 rounded-full bg-orange-100 text-orange-700 font-bold text-sm">
													⏱️ {formatDuration(trip.duration)}
												</div>
											</div>

											<!-- Destination Station -->
											<div class="md:col-span-3 text-center md:text-left">
												<div class="inline-block mb-2 px-3 py-1 rounded-full bg-gradient-to-r from-orange-100 to-pink-100 text-orange-700 text-xs font-bold">
													ARRIVAL
												</div>
												<div class="text-4xl font-black text-gray-800">{formatDateTime(trip.arrivalDateTime)}</div>
												<div class="text-xl font-bold text-orange-600 mt-2 flex items-center justify-center md:justify-start gap-2">
													<span>🎯</span>
													<span>{trip.destination}</span>
												</div>
											</div>

											<!-- Trip Details -->
											<div class="md:col-span-3 space-y-3">
												<div class="flex items-center gap-2 text-sm">
													<span class="px-3 py-1 rounded-full bg-gradient-to-r from-blue-500 to-indigo-500 text-white font-bold text-xs">
														{trip.carrier}
													</span>
												</div>
												{trip.stops && trip.stops.length > 0 && (
													<div class="flex items-start gap-2">
														<span class="text-xs font-bold text-gray-500 mt-1">🛤️ STOPS:</span>
														<span class="text-sm text-gray-600 font-medium">{trip.stops}</span>
													</div>
												)}
												{(!trip.stops || trip.stops.length === 0) && (
													<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-green-100 text-green-700 font-bold text-xs">
														<span>⚡</span>
														<span>DIRECT ROUTE</span>
													</div>
												)}
											</div>
										</div>
									</div>
								</div>
							))}
						</div>
					</>
				) : (
					<div class="glass rounded-3xl p-12 text-center border-2 border-orange-200">
						<div class="text-6xl mb-6">😕</div>
						<h3 class="text-3xl font-black text-gray-800 mb-4">
							No trips found
						</h3>
						<p class="text-xl text-gray-600 mb-2">
							We couldn't find any trains matching your search.
						</p>
						<p class="text-gray-500">
							Try adjusting your search parameters or selecting different dates.
						</p>
					</div>
				)}
			</section>
		)}

		{!origin && !destination && !departureDate && (
			<section class="max-w-4xl mx-auto text-center">
				<div class="bg-blue-50 border border-blue-200 rounded-lg p-8">
					<p class="text-lg text-gray-700">
						Enter your travel details above to search for available trains.
					</p>
					<p class="text-gray-600 mt-2">
						Search across 10 Italian cities with 100+ routes available.
					</p>
				</div>
			</section>
		)}
	</main>
</Layout>
