---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import { db, RailTrip, eq, and, gte } from 'astro:db';

// Get search params from URL
const url = new URL(Astro.request.url);
const origin = url.searchParams.get('origin') || '';
const destination = url.searchParams.get('destination') || '';
const departureDate = url.searchParams.get('departureDate') || '';

// Query rail trips based on search criteria
let trips = [];
if (origin || destination || departureDate) {
  // Build filter conditions
  let allTrips = await db.select().from(RailTrip).all();

  trips = allTrips.filter(trip => {
    let matches = true;

    if (origin && trip.origin !== origin) {
      matches = false;
    }

    if (destination && trip.destination !== destination) {
      matches = false;
    }

    if (departureDate) {
      const searchDate = new Date(departureDate);
      const tripDate = new Date(trip.departureDateTime);
      // Compare only the date part (ignore time)
      searchDate.setHours(0, 0, 0, 0);
      tripDate.setHours(0, 0, 0, 0);

      if (tripDate < searchDate) {
        matches = false;
      }
    }

    return matches;
  });
}

// Helper function to format duration
function formatDuration(minutes: number): string {
  const hours = Math.floor(minutes / 60);
  const mins = minutes % 60;
  if (hours === 0) return `${mins}m`;
  if (mins === 0) return `${hours}h`;
  return `${hours}h ${mins}m`;
}

// Helper function to format date/time
function formatDateTime(dateTime: Date): string {
  const date = new Date(dateTime);
  return date.toLocaleTimeString('en-US', {
    hour: '2-digit',
    minute: '2-digit',
    hour12: false
  });
}

// Get unique cities for datalist suggestions
const allTrips = await db.select().from(RailTrip).all();
const cities = [...new Set([
  ...allTrips.map(t => t.origin),
  ...allTrips.map(t => t.destination)
])].sort();
---

<Layout>
	<Navigation currentPath="/rail-search" />

	<main class="container mx-auto px-4 py-12">
		<section class="text-center mb-12">
			<h1 class="text-5xl font-bold text-blue-600 mb-4">Rail Search</h1>
			<p class="text-xl text-gray-600">Find your perfect train journey across Italy</p>
		</section>

		<!-- Search Form -->
		<section class="max-w-4xl mx-auto mb-12">
			<form method="GET" action="/rail-search" class="bg-white rounded-lg shadow-lg p-8">
				<div class="grid md:grid-cols-3 gap-6">
					<div>
						<label for="origin" class="block text-sm font-semibold text-gray-700 mb-2">
							Origin
						</label>
						<input
							type="text"
							id="origin"
							name="origin"
							value={origin}
							list="cities"
							placeholder="e.g., Rome"
							class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
						/>
					</div>

					<div>
						<label for="destination" class="block text-sm font-semibold text-gray-700 mb-2">
							Destination
						</label>
						<input
							type="text"
							id="destination"
							name="destination"
							value={destination}
							list="cities"
							placeholder="e.g., Milan"
							class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
						/>
					</div>

					<div>
						<label for="departureDate" class="block text-sm font-semibold text-gray-700 mb-2">
							Departure Date
						</label>
						<input
							type="date"
							id="departureDate"
							name="departureDate"
							value={departureDate}
							class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
						/>
					</div>
				</div>

				<div class="mt-6 text-center">
					<button
						type="submit"
						class="bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-700 transition-colors"
					>
						Search Trains
					</button>
				</div>
			</form>

			<!-- Datalist for city suggestions -->
			<datalist id="cities">
				{cities.map(city => <option value={city} />)}
			</datalist>
		</section>

		<!-- Search Results -->
		{(origin || destination || departureDate) && (
			<section class="max-w-6xl mx-auto">
				{trips.length > 0 ? (
					<>
						<h2 class="text-2xl font-bold text-gray-800 mb-6">
							Found {trips.length} {trips.length === 1 ? 'trip' : 'trips'}
						</h2>
						<div class="space-y-4">
							{trips.map((trip) => (
								<div class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow">
									<div class="grid md:grid-cols-5 gap-4 items-center">
										<!-- Origin & Time -->
										<div class="text-center">
											<div class="text-2xl font-bold text-gray-800">{formatDateTime(trip.departureDateTime)}</div>
											<div class="text-lg font-semibold text-blue-600 mt-1">{trip.origin}</div>
										</div>

										<!-- Arrow & Duration -->
										<div class="text-center">
											<div class="text-gray-400 text-2xl">→</div>
											<div class="text-sm text-gray-600 mt-1">{formatDuration(trip.duration)}</div>
										</div>

										<!-- Destination & Time -->
										<div class="text-center">
											<div class="text-2xl font-bold text-gray-800">{formatDateTime(trip.arrivalDateTime)}</div>
											<div class="text-lg font-semibold text-blue-600 mt-1">{trip.destination}</div>
										</div>

										<!-- Carrier & Stops -->
										<div class="md:col-span-2">
											<div class="text-sm font-semibold text-gray-700">{trip.carrier}</div>
											{trip.stops && trip.stops.length > 0 && (
												<div class="text-sm text-gray-600 mt-1">
													<span class="font-medium">Stops:</span> {trip.stops}
												</div>
											)}
											{(!trip.stops || trip.stops.length === 0) && (
												<div class="text-sm text-green-600 mt-1">Direct</div>
											)}
										</div>
									</div>
								</div>
							))}
						</div>
					</>
				) : (
					<div class="bg-yellow-50 border border-yellow-200 rounded-lg p-8 text-center">
						<p class="text-xl text-gray-700">
							No trips found matching your search criteria.
						</p>
						<p class="text-gray-600 mt-2">
							Try adjusting your search parameters or selecting different dates.
						</p>
					</div>
				)}
			</section>
		)}

		{!origin && !destination && !departureDate && (
			<section class="max-w-4xl mx-auto text-center">
				<div class="bg-blue-50 border border-blue-200 rounded-lg p-8">
					<p class="text-lg text-gray-700">
						Enter your travel details above to search for available trains.
					</p>
					<p class="text-gray-600 mt-2">
						Search across 10 Italian cities with 100+ routes available.
					</p>
				</div>
			</section>
		)}
	</main>
</Layout>
