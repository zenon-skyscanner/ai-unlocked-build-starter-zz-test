---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
---

<Layout>
	<Navigation currentPath="/contact" />
	
	<main class="container mx-auto px-4 py-12">
		<section class="text-center mb-16">
			<h1 class="text-5xl font-bold text-blue-600 mb-4">Contact Us</h1>
			<p class="text-xl text-gray-600">We'd love to hear from you</p>
		</section>

		<section class="max-w-2xl mx-auto">
			<div class="bg-white border rounded-lg p-8 shadow-lg mb-8">
				<h2 class="text-2xl font-bold mb-6">Get in Touch</h2>
				<form class="space-y-6">
					<div>
						<label for="name" class="block text-gray-700 font-semibold mb-2">Name</label>
						<input type="text" id="name" name="name" class="w-full border rounded px-4 py-2" required />
					</div>

					<div>
						<label for="email" class="block text-gray-700 font-semibold mb-2">Email</label>
						<input type="email" id="email" name="email" class="w-full border rounded px-4 py-2" required />
					</div>

					<div>
						<label for="message" class="block text-gray-700 font-semibold mb-2">Message</label>
						<textarea id="message" name="message" rows="5" class="w-full border rounded px-4 py-2" required></textarea>
					</div>

					<button type="submit" class="bg-blue-600 text-white px-8 py-3 rounded font-semibold hover:bg-blue-700">
						Send Message
					</button>
				</form>
			</div>

			<div class="text-center text-gray-700">
				<h3 class="text-xl font-bold mb-4">Other Ways to Reach Us</h3>
				<p class="mb-2"><strong>Email:</strong> info@travelcompany.com</p>
				<p class="mb-2"><strong>Phone:</strong> +1 (555) 123-4567</p>
				<p><strong>Address:</strong> 123 Travel Street, Adventure City, AC 12345</p>
			</div>
		</section>
	</main>
</Layout>
