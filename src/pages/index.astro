---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Products from '../components/Products';
---

<Layout>
	<Navigation currentPath="/" />
	
	<main class="container mx-auto px-4 py-12">
		<section class="text-center mb-16">
			<h1 class="text-5xl font-bold text-blue-600 mb-4">Welcome to Travel Company</h1>
			<p class="text-xl text-gray-600">Your adventure starts here</p>
		</section>

		<section class="max-w-3xl mx-auto mb-16">
			<h2 class="text-3xl font-bold mb-6">Discover Your Next Destination</h2>
			<p class="text-lg text-gray-700 mb-4">
				We help you explore the world with carefully curated travel experiences. 
				Whether you're looking for adventure, relaxation, or cultural immersion, 
				we have the perfect journey for you.
			</p>
			<p class="text-lg text-gray-700">
				Browse our products to find amazing travel packages and destinations.
			</p>
		</section>

		<section class="max-w-6xl mx-auto">
			<h2 class="text-3xl font-bold mb-8 text-center">Featured Travel Packages</h2>
			<Products client:load />
		</section>
	</main>
</Layout>
