---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Products from '../components/Products';
---

<Layout>
	<Navigation currentPath="/" />
	
	<main class="relative">
		<!-- Hero Section with creative layout -->
		<section class="relative overflow-hidden py-20 wave-divider">
			<div class="absolute inset-0 dots-pattern opacity-30"></div>

			<div class="container mx-auto px-4 relative z-10">
				<div class="max-w-5xl mx-auto">
					<!-- Floating badge -->
					<div class="flex justify-center mb-8 animate-fadeInUp">
						<span class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-gradient-to-r from-purple-100 to-pink-100 border-2 border-purple-200 text-purple-700 font-semibold shadow-lg animate-pulse-slow">
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
								<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
							</svg>
							Your #1 Travel Companion
						</span>
					</div>

					<!-- Main heading with staggered animation -->
					<h1 class="text-7xl md:text-8xl font-black text-center mb-6 animate-fadeInUp">
						<span class="block heading-gradient mb-2">Welcome to</span>
						<span class="block text-gray-800">McClickity <span class="text-orange-500">Trip</span></span>
					</h1>

					<p class="text-2xl md:text-3xl text-center text-gray-600 mb-12 animate-fadeInUp font-light">
						Your adventure starts with a <span class="relative inline-block">
							<span class="text-orange-500 font-bold">click</span>
							<svg class="absolute -bottom-2 left-0 w-full" height="8" viewBox="0 0 100 8" preserveAspectRatio="none">
								<path d="M0,4 Q25,8 50,4 T100,4" stroke="#fb923c" stroke-width="3" fill="none"/>
							</svg>
						</span> ✈️
					</p>

					<!-- CTA Buttons with icon -->
					<div class="flex flex-col sm:flex-row gap-6 justify-center items-center animate-slideInRight">
						<a href="/rail-search" class="btn-primary group">
							🚄 Search Rail Trips
							<svg class="inline-block w-5 h-5 ml-2 transform group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
							</svg>
						</a>
						<a href="/products" class="btn-secondary group">
							🎒 Explore Packages
							<svg class="inline-block w-5 h-5 ml-2 transform group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
							</svg>
						</a>
					</div>

					<!-- Floating stats -->
					<div class="grid grid-cols-3 gap-6 mt-20 max-w-3xl mx-auto">
						<div class="text-center glass rounded-2xl p-6 animate-fadeInUp">
							<div class="text-4xl font-bold heading-gradient">10+</div>
							<div class="text-sm text-gray-600 mt-2">Italian Cities</div>
						</div>
						<div class="text-center glass rounded-2xl p-6 animate-fadeInUp" style="animation-delay: 0.1s">
							<div class="text-4xl font-bold heading-gradient">100+</div>
							<div class="text-sm text-gray-600 mt-2">Rail Routes</div>
						</div>
						<div class="text-center glass rounded-2xl p-6 animate-fadeInUp" style="animation-delay: 0.2s">
							<div class="text-4xl font-bold heading-gradient">∞</div>
							<div class="text-sm text-gray-600 mt-2">Adventures</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- About Section with creative layout -->
		<section class="py-20 bg-white">
			<div class="container mx-auto px-4">
				<div class="max-w-6xl mx-auto">
					<div class="grid md:grid-cols-2 gap-12 items-center">
						<!-- Left: Text content -->
						<div class="animate-slideInRight">
							<div class="inline-block px-4 py-2 rounded-full bg-purple-100 text-purple-700 font-semibold text-sm mb-6">
								✨ Why Choose Us
							</div>
							<h2 class="text-5xl font-black mb-6 heading-gradient">Discover Your Next Destination</h2>
							<p class="text-xl text-gray-600 mb-6 leading-relaxed">
								We help you explore the world with carefully curated travel experiences.
								Whether you're looking for adventure, relaxation, or cultural immersion,
								we have the perfect journey for you.
							</p>
							<div class="space-y-4">
								<div class="flex items-start gap-4">
									<div class="flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-br from-purple-400 to-pink-400 flex items-center justify-center text-white font-bold">✓</div>
									<div>
										<h3 class="font-bold text-lg">Curated Experiences</h3>
										<p class="text-gray-600">Hand-picked destinations and authentic local experiences</p>
									</div>
								</div>
								<div class="flex items-start gap-4">
									<div class="flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-br from-orange-400 to-pink-400 flex items-center justify-center text-white font-bold">✓</div>
									<div>
										<h3 class="font-bold text-lg">Easy Booking</h3>
										<p class="text-gray-600">Simple rail search and instant confirmations</p>
									</div>
								</div>
								<div class="flex items-start gap-4">
									<div class="flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-br from-indigo-400 to-purple-400 flex items-center justify-center text-white font-bold">✓</div>
									<div>
										<h3 class="font-bold text-lg">24/7 Support</h3>
										<p class="text-gray-600">We're here for you every step of the journey</p>
									</div>
								</div>
							</div>
						</div>

						<!-- Right: Decorative element -->
						<div class="relative animate-fadeInUp">
							<div class="relative z-10 rounded-3xl overflow-hidden shadow-2xl">
								<div class="aspect-square bg-gradient-to-br from-purple-400 via-pink-400 to-orange-400 p-12 flex items-center justify-center">
									<div class="text-white text-center">
										<div class="text-6xl mb-4">🌍</div>
										<div class="text-3xl font-bold mb-2">Explore Italy</div>
										<div class="text-lg opacity-90">From Rome to Venice</div>
									</div>
								</div>
							</div>
							<div class="absolute -top-6 -right-6 w-32 h-32 bg-yellow-300 rounded-full opacity-50 blur-2xl"></div>
							<div class="absolute -bottom-6 -left-6 w-40 h-40 bg-purple-300 rounded-full opacity-50 blur-2xl"></div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Featured Packages Section -->
		<section class="py-20">
			<div class="container mx-auto px-4">
				<div class="max-w-6xl mx-auto">
					<div class="text-center mb-16">
						<h2 class="text-5xl font-black heading-gradient mb-4">Featured Travel Packages</h2>
						<p class="text-xl text-gray-600">Handpicked journeys for unforgettable experiences</p>
					</div>
					<Products client:load />
				</div>
			</div>
		</section>
	</main>
</Layout>
